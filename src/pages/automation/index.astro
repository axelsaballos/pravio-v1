---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { automationTemplates, categories } from '../../data/automation';
---

<BaseLayout
  title="Automation Templates — Pravio"
  description="Production-ready QA automation templates built from real engagements. Browse by category and drop them into your stack."
>
  <Nav />

  <main>
    <!-- Header -->
    <section class="max-w-[900px] mx-auto px-8 pt-16 pb-12">
      <a
        href="/#automation"
        class="inline-flex items-center gap-1.5 text-[12px] text-navy opacity-50 hover:opacity-80 transition-opacity mb-8 no-underline"
      >
        <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 3L5 8l5 5"/>
        </svg>
        Back to home
      </a>

      <p class="text-[11px] uppercase tracking-[0.1em] text-blue mb-3">Automation Templates</p>
      <h1 class="font-serif text-[48px] font-normal leading-[1.15] text-navy mb-5 max-w-[680px]">
        Start faster.<br />Ship with confidence.
      </h1>
      <p class="text-[17px] font-light leading-[1.75] text-navy opacity-70 max-w-[540px]">
        Production-ready templates built from real engagements. Pick one, drop it into your stack,
        and skip the setup boilerplate entirely.
      </p>
    </section>

    <!-- Tabs + Grid -->
    <section
      class="border-t border-border py-12 px-8"
      style="border-top-width: 0.5px;"
    >
      <div class="max-w-[900px] mx-auto">

        <!-- Tab buttons -->
        <div class="flex flex-wrap gap-2 mb-10" role="tablist" aria-label="Filter by category">
          {categories.map((cat, i) => (
            <button
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-category={cat}
              class:list={[
                'px-4 py-2 rounded-[8px] text-[12px] font-medium tracking-[0.02em] border transition-all duration-150',
                i === 0
                  ? 'bg-navy text-bg border-navy'
                  : 'bg-white text-navy border-border opacity-60 hover:opacity-100',
              ]}
              style="border-width: 0.5px;"
            >
              {cat}
            </button>
          ))}
        </div>

        <!-- Template cards -->
        <ul
          id="template-grid"
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none m-0 p-0"
          role="list"
        >
          {automationTemplates.map((tpl) => (
            <li
              data-category={tpl.category}
              class="bg-white border border-border rounded-[14px] p-6 flex flex-col gap-4 transition-all duration-200 ease-out hover:border-blue hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(45,58,82,0.1)]"
              style="border-width: 0.5px;"
            >
              <!-- Category + badge -->
              <div class="flex items-start justify-between gap-2">
                <span class="text-[11px] uppercase tracking-[0.08em] text-blue font-medium">
                  {tpl.category}
                </span>
                {tpl.badge && (
                  <span class="text-[10px] uppercase tracking-[0.06em] font-medium px-2 py-0.5 rounded-full bg-card-bg text-navy opacity-70">
                    {tpl.badge}
                  </span>
                )}
              </div>

              <!-- Title + description -->
              <div class="flex-1">
                <h3 class="text-[15px] font-medium text-navy mb-1.5">{tpl.name}</h3>
                <p class="text-[13px] font-light text-navy opacity-65 leading-[1.65]">
                  {tpl.description}
                </p>
              </div>

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5">
                {tpl.tags.map((tag) => (
                  <span class="text-[11px] font-normal text-navy opacity-50 bg-card-bg rounded-[6px] px-2 py-0.5">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Actions -->
              <div
                class="flex items-center gap-2 pt-3 border-t border-border"
                style="border-top-width: 0.5px;"
              >
                <a
                  href={tpl.purchaseUrl ?? '#contact'}
                  class="flex-1 text-center bg-navy text-bg py-2.5 rounded-[8px] text-[12px] font-medium tracking-[0.02em] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_4px_10px_rgba(45,58,82,0.2)] active:translate-y-0"
                >
                  Get template
                </a>
                <a
                  href="#request-custom"
                  class="px-3 py-2.5 rounded-[8px] text-[12px] font-normal text-navy border border-border transition-all duration-150 hover:border-blue hover:-translate-y-0.5 active:translate-y-0 whitespace-nowrap"
                  style="border-width: 0.5px;"
                >
                  Request custom
                </a>
              </div>
            </li>
          ))}
        </ul>

      </div>
    </section>

    <!-- Request custom section -->
    <section
      id="request-custom"
      class="bg-white border-t border-border py-16 px-8"
      style="border-top-width: 0.5px;"
    >
      <div class="max-w-[900px] mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
        <div>
          <p class="text-[11px] uppercase tracking-[0.1em] text-blue mb-3">Custom Templates</p>
          <h2 class="font-serif text-[30px] font-normal text-navy leading-[1.2] mb-2">
            Don't see what you need?
          </h2>
          <p class="text-[15px] font-light text-navy opacity-60 max-w-[440px] leading-[1.7]">
            Tell us your stack and requirements and we'll build a template specifically for your setup.
          </p>
        </div>
        <a
          href="/#contact"
          class="shrink-0 bg-navy text-bg px-7 py-[13px] rounded-[10px] text-[14px] font-medium tracking-[0.02em] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_4px_14px_rgba(45,58,82,0.22)] active:translate-y-0 whitespace-nowrap"
        >
          Request a custom template
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const tabs  = document.querySelectorAll<HTMLButtonElement>('[role="tab"]');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');

  function filterBy(selected: string) {
    tabs.forEach((tab) => {
      const active = tab.dataset.category === selected;
      tab.setAttribute('aria-selected', String(active));
      tab.classList.toggle('bg-navy',     active);
      tab.classList.toggle('text-bg',     active);
      tab.classList.toggle('border-navy', active);
      tab.classList.toggle('bg-white',    !active);
      tab.classList.toggle('text-navy',   !active);
      tab.classList.toggle('border-border', !active);
      tab.classList.toggle('opacity-60',  !active);
    });

    cards.forEach((card) => {
      const match = selected === 'All' || card.dataset.category === selected;
      card.style.display = match ? '' : 'none';
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => filterBy(tab.dataset.category ?? 'All'));
  });
</script>
