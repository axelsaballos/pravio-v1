---
const currentYear = new Date().getFullYear();

const links = [
  { label: 'Services', href: '#services' },
  { label: 'Process',  href: '#process'  },
  { label: 'Contact',  href: '#contact'  },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-copy">&copy; {currentYear} Pravio. All rights reserved.</span>
    <ul class="footer-links" role="list">
      {links.map(({ label, href }) => (
        <li><a href={href}>{label}</a></li>
      ))}
    </ul>
  </div>
</footer>

<style>
.site-footer { border-top: 1px solid #E2E8F4; padding: 28px 3rem; }
.footer-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
.footer-copy  { font-size: 12px; color: rgba(45,58,82,.35); }
.footer-links { display: flex; gap: 24px; list-style: none; margin: 0; padding: 0; }
.footer-links a { font-size: 12px; color: rgba(45,58,82,.35); text-decoration: none; transition: color .15s; }
.footer-links a:hover { color: rgba(45,58,82,.7); }
@media (max-width: 640px) {
  .site-footer { padding: 24px 1.25rem; }
  .footer-inner { flex-direction: column; gap: 12px; align-items: flex-start; }
}
</style>
