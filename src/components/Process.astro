---
import { processSteps } from '../data/process';
---

<section
  id="process"
  class="bg-white border-y border-border py-16 px-8"
  style="border-top-width: 0.5px; border-bottom-width: 0.5px;"
>
  <div class="max-w-[900px] mx-auto">
    <p class="text-[11px] uppercase tracking-[0.1em] text-blue mb-3">How we work</p>
    <h2 class="font-serif text-[36px] font-normal text-navy leading-[1.2]">
      From zero to operational.
    </h2>

    <ol
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-0 mt-11 list-none m-0 p-0"
      role="list"
    >
      {processSteps.map((step, index) => (
        <li
          class:list={[
            'pr-6 relative',
            index > 0 && 'lg:pl-6',
          ]}
        >
          {index < processSteps.length - 1 && (
            <div
              class="hidden lg:block absolute right-0 top-4 w-px h-10 bg-border"
              aria-hidden="true"
            />
          )}
          <div class="text-[11px] text-blue tracking-[0.08em] mb-2.5 font-medium">
            {step.number} — {step.phase}
          </div>
          <h4 class="text-[14px] font-medium text-navy mb-1.5">{step.title}</h4>
          <p class="text-[12px] font-light text-navy opacity-55 leading-[1.6]">
            {step.description}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
