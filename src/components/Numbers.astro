<section class="numbers reveal">
  <div class="numbers-inner">
    <div class="num-cell">
      <div class="num-val">100<span>%</span></div>
      <div class="num-label">Of our projects are built from zero. No copy-paste frameworks, no generic templates.</div>
    </div>
    <div class="num-cell">
      <div class="num-val">6</div>
      <div class="num-label">Core services covering the full QA lifecycle, from strategy to team building.</div>
    </div>
    <div class="num-cell">
      <div class="num-val num-end">End&#8209;to&#8209;end</div>
      <div class="num-label">Strategy to staffing, automation to training. One partner for every QA need.</div>
    </div>
  </div>
</section>

<style>
.numbers { background: white; padding: 100px 3rem; border-top: 1px solid #E2E8F4; border-bottom: 1px solid #E2E8F4; }
.numbers-inner {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px; background: #E2E8F4; border-radius: 16px; overflow: hidden;
}
.num-cell { background: white; padding: 48px 40px; }
.num-val  { font-size: clamp(52px, 6vw, 72px); font-weight: 200; letter-spacing: -.05em; color: #2D3A52; line-height: 1; margin-bottom: 8px; }
.num-val span { color: #7B9ED9; }
.num-end  { font-size: clamp(32px, 4vw, 48px); letter-spacing: -.03em; }
.num-label { font-size: 13px; font-weight: 300; color: rgba(45,58,82,.5); line-height: 1.6; }
@media (max-width: 960px) {
  .numbers { padding-left: 1.5rem; padding-right: 1.5rem; }
  .numbers-inner { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .numbers { padding-left: 1.25rem; padding-right: 1.25rem; }
  .numbers-inner { grid-template-columns: 1fr; }
}
</style>
