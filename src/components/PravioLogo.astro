---
interface Props {
  size?: number;
}
const { size = 28 } = Astro.props;
---

<svg
  viewBox="0 0 28 28"
  width={size}
  height={size}
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Pravio logo"
  role="img"
>
  <rect x="0" y="0" width="28" height="28" rx="6" fill="#7B9ED9" />
  <path
    d="M8 18 L14 7 L20 18"
    fill="none"
    stroke="#fff"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <path
    d="M5 21 L14 4 L23 21"
    fill="none"
    stroke="#fff"
    stroke-width="1.1"
    stroke-linecap="round"
    stroke-linejoin="round"
    opacity="0.28"
  />
  <line x1="5" y1="21" x2="23" y2="21" stroke="#fff" stroke-width="2" stroke-linecap="round" />
  <circle cx="14" cy="21" r="2.2" fill="#B8D4C8" />
</svg>
