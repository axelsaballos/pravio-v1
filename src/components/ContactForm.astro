---
/**
 * Contact form powered by Formspree.
 * Replace FORMSPREE_FORM_ID in .env with your actual form ID from formspree.io.
 * The form ID is exposed client-side intentionally — it is not a secret.
 */
const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID ?? 'YOUR_FORM_ID';
const action = `https://formspree.io/f/${formId}`;
---

<section id="contact" class="bg-bg border-t border-border py-16 px-8" style="border-top-width:0.5px;">
  <div class="max-w-[560px] mx-auto">
    <p class="text-[11px] uppercase tracking-[0.1em] text-blue mb-3">Get in touch</p>
    <h2 class="font-serif text-[36px] font-normal text-navy leading-[1.2] mb-2.5">
      Let's build your<br /><em class="not-italic text-blue">quality foundation.</em>
    </h2>
    <p class="text-[15px] font-light text-navy opacity-60 leading-[1.7] mb-10">
      Tell us about your project and we'll get back to you within one business day.
    </p>

    <form
      id="contact-form"
      action={action}
      method="POST"
      novalidate
      class="flex flex-col gap-4"
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col gap-1.5">
          <label for="name" class="text-[12px] font-medium text-navy tracking-[0.02em]">
            Name <span class="text-blue" aria-hidden="true">*</span>
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder="Jane Smith"
            class="bg-white border border-border rounded-[8px] px-4 py-3 text-[14px] text-navy placeholder:opacity-40 focus:outline-none focus:border-blue transition-colors"
            style="border-width: 0.5px;"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-[12px] font-medium text-navy tracking-[0.02em]">
            Email <span class="text-blue" aria-hidden="true">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="jane@company.com"
            class="bg-white border border-border rounded-[8px] px-4 py-3 text-[14px] text-navy placeholder:opacity-40 focus:outline-none focus:border-blue transition-colors"
            style="border-width: 0.5px;"
          />
        </div>
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="company" class="text-[12px] font-medium text-navy tracking-[0.02em]">
          Company
        </label>
        <input
          id="company"
          name="company"
          type="text"
          autocomplete="organization"
          placeholder="Acme Inc."
          class="bg-white border border-border rounded-[8px] px-4 py-3 text-[14px] text-navy placeholder:opacity-40 focus:outline-none focus:border-blue transition-colors"
          style="border-width: 0.5px;"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="message" class="text-[12px] font-medium text-navy tracking-[0.02em]">
          Message <span class="text-blue" aria-hidden="true">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder="Tell us about your project, your team size, and your current QA situation..."
          class="bg-white border border-border rounded-[8px] px-4 py-3 text-[14px] text-navy placeholder:opacity-40 focus:outline-none focus:border-blue transition-colors resize-none"
          style="border-width: 0.5px;"
        ></textarea>
      </div>

      <!-- Honeypot — catches bots without a CAPTCHA -->
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" aria-hidden="true" />

      <!-- Status message (shown via JS) -->
      <p
        id="form-status"
        role="status"
        aria-live="polite"
        class="hidden text-[13px] font-medium"
      ></p>

      <button
        type="submit"
        id="form-submit"
        class="self-start bg-navy text-bg px-7 py-[13px] rounded-[10px] text-[14px] font-medium tracking-[0.02em] transition-all duration-150 hover:-translate-y-0.5 hover:shadow-[0_4px_14px_rgba(45,58,82,0.22)] active:translate-y-0 disabled:opacity-50 disabled:translate-y-0 disabled:shadow-none"
      >
        Send message
      </button>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;
  const submit = document.getElementById('form-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !status || !submit) return;

    submit.disabled = true;
    submit.textContent = 'Sending…';
    status.className = 'hidden text-[13px] font-medium';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        status.textContent = "Message sent — we'll be in touch within one business day.";
        status.className = 'text-[13px] font-medium text-blue';
        form.reset();
        submit.textContent = 'Send message';
        submit.disabled = false;
      } else {
        const data = await res.json().catch(() => ({}));
        throw new Error((data as any).error ?? 'Submission failed');
      }
    } catch (err) {
      status.textContent = 'Something went wrong. Please email us directly.';
      status.className = 'text-[13px] font-medium text-red-500';
      submit.textContent = 'Send message';
      submit.disabled = false;
    }
  });
</script>
