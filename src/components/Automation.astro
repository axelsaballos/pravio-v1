---
import { automationTemplates } from '../data/automation';

const featured = automationTemplates.filter((t) => t.featured);
---

<section
  id="automation"
  class="bg-bg border-b border-border py-16 px-8"
  style="border-bottom-width: 0.5px;"
>
  <div class="max-w-[900px] mx-auto">
    <p class="text-[11px] uppercase tracking-[0.1em] text-blue mb-3">Automation Templates</p>
    <h2 class="font-serif text-[36px] font-normal text-navy leading-[1.2] mb-2.5">
      Start faster.<br />Ship with confidence.
    </h2>
    <p class="text-[15px] font-light text-navy opacity-60 max-w-[480px] leading-[1.7] mb-11">
      Production-ready automation templates built from real engagements. Drop them into your
      stack and skip the setup boilerplate.
    </p>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none m-0 p-0" role="list">
      {featured.map((tpl) => (
        <li class="bg-white border border-border rounded-[14px] p-6 flex flex-col gap-3 transition-all duration-200 ease-out hover:border-blue hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(45,58,82,0.1)]" style="border-width: 0.5px;">
          <div class="flex items-start justify-between gap-2">
            <span class="text-[11px] uppercase tracking-[0.08em] text-blue font-medium">
              {tpl.category}
            </span>
            {tpl.badge && (
              <span class="text-[10px] uppercase tracking-[0.06em] font-medium px-2 py-0.5 rounded-full bg-card-bg text-navy opacity-70">
                {tpl.badge}
              </span>
            )}
          </div>
          <div>
            <h3 class="text-[15px] font-medium text-navy mb-1.5">{tpl.name}</h3>
            <p class="text-[13px] font-light text-navy opacity-65 leading-[1.65]">
              {tpl.description}
            </p>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-auto pt-1">
            {tpl.tags.map((tag) => (
              <span class="text-[11px] font-normal text-navy opacity-50 bg-card-bg rounded-[6px] px-2 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        </li>
      ))}
    </ul>

    <!-- CTA al catálogo completo -->
    <div
      class="mt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8 border-t border-border"
      style="border-top-width: 0.5px;"
    >
      <p class="text-[14px] font-light text-navy opacity-60">
        6 templates available — browse the full catalog.
      </p>
      <a
        href="/automation"
        class="text-[13px] font-medium text-blue hover:opacity-75 transition-opacity tracking-[0.02em] whitespace-nowrap"
      >
        View all templates →
      </a>
    </div>
  </div>
</section>
