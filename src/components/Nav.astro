---
---

<header id="site-header" class="site-header">
  <a href="/" class="logo" aria-label="Pravio home">
    <svg viewBox="0 0 28 28" width="28" height="28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="28" height="28" rx="6" fill="#7B9ED9"/>
      <path d="M8 18L14 7L20 18" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M5 21L14 4L23 21" stroke="white" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" opacity="0.28"/>
      <line x1="5" y1="21" x2="23" y2="21" stroke="white" stroke-width="2" stroke-linecap="round"/>
      <circle cx="14" cy="21" r="2.2" fill="#B8D4C8"/>
    </svg>
    <span class="logo-name">pravio</span>
  </a>

  <ul class="nav-links" role="list">
    <li><a href="#services">Services</a></li>
    <li><a href="#process">Process</a></li>
    <li><a href="#automation">Templates</a></li>
  </ul>

  <a href="#contact" class="nav-cta">Let's talk</a>
</header>

<style>
.site-header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0 3rem; height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  transition: background .3s, backdrop-filter .3s, border-color .3s;
}
.site-header.scrolled {
  background: rgba(244, 246, 251, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid #E2E8F4;
}
.logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.logo-name { font-size: 15px; font-weight: 400; letter-spacing: .18em; color: #2D3A52; }
.nav-links { display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; }
.nav-links a { font-size: 13px; color: rgba(45,58,82,.6); text-decoration: none; transition: color .2s; letter-spacing: .02em; }
.nav-links a:hover { color: #2D3A52; }
.nav-cta {
  font-size: 13px; font-weight: 500; color: white;
  background: #2D3A52; padding: 9px 22px; border-radius: 99px;
  text-decoration: none; letter-spacing: .02em;
  transition: transform .2s cubic-bezier(.32,.72,0,1), box-shadow .2s;
}
.nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(45,58,82,.25); }
@media (max-width: 640px) {
  .site-header { padding: 0 1.25rem; }
  .nav-links { display: none; }
}
@media (max-width: 960px) {
  .site-header { padding: 0 1.5rem; }
}
</style>
