---
---

<section class="hero" aria-label="Hero">
  <div class="hero-bg">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  <div class="hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      QA Consulting Agency
    </div>
    <h1 class="hero-h1">
      <span>Your quality</span>
      <span class="line-medium">foundation,</span>
      <span class="line-blue">built from scratch.</span>
    </h1>
    <p class="hero-sub">We partner with companies that have no QA structure and guide them through every step, from strategy and process design to automation and team building.</p>
    <div class="hero-btns">
      <a href="#contact" class="btn-fill">
        Start a project
        <span class="btn-fill-arrow">&#8599;</span>
      </a>
      <a href="#services" class="btn-line">See our services</a>
    </div>
  </div>
  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
.hero {
  position: relative; height: 100dvh; min-height: 600px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; overflow: hidden; padding: 0 2rem;
}
.hero-bg { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.orb { position: absolute; border-radius: 50%; filter: blur(80px); animation: orbFloat 12s ease-in-out infinite; }
.orb-1 { width: 600px; height: 600px; background: rgba(123,158,217,.18); top: -200px; left: -100px; animation-delay: 0s; }
.orb-2 { width: 500px; height: 500px; background: rgba(184,212,200,.15); bottom: -150px; right: -80px; animation-delay: -4s; }
.orb-3 { width: 400px; height: 400px; background: rgba(168,197,218,.12); top: 30%; left: 40%; animation-delay: -8s; }
@keyframes orbFloat {
  0%,100% { transform: translate(0,0) scale(1); }
  33%      { transform: translate(40px,-30px) scale(1.05); }
  66%      { transform: translate(-20px,20px) scale(.95); }
}
.hero-content { position: relative; z-index: 1; max-width: 900px; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,.7); border: 1px solid #E2E8F4;
  border-radius: 99px; padding: 6px 16px;
  font-family: var(--font-mono); font-size: 11px; color: #7B9ED9;
  letter-spacing: .06em; text-transform: uppercase;
  margin-bottom: 40px; backdrop-filter: blur(10px);
  opacity: 0; animation: fadeUp .8s cubic-bezier(.16,1,.3,1) .2s forwards;
}
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #B8D4C8; flex-shrink: 0; animation: pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
.hero-h1 {
  font-size: clamp(52px, 8vw, 96px); font-weight: 200;
  letter-spacing: -.04em; line-height: 1.02; color: #2D3A52;
  display: flex; flex-direction: column;
  opacity: 0; animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .4s forwards;
}
.line-medium { font-weight: 400; }
.line-blue   { color: #7B9ED9; }
.hero-sub {
  font-size: clamp(15px, 1.8vw, 18px); font-weight: 300;
  color: rgba(45,58,82,.6); line-height: 1.8;
  max-width: 52ch; margin: 28px auto 44px;
  opacity: 0; animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .6s forwards;
}
.hero-btns {
  display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
  opacity: 0; animation: fadeUp .9s cubic-bezier(.16,1,.3,1) .8s forwards;
}
.btn-fill {
  display: inline-flex; align-items: center; gap: 10px;
  background: #2D3A52; color: white;
  font-size: 15px; font-weight: 400; padding: 14px 28px;
  border-radius: 99px; text-decoration: none;
  transition: transform .25s cubic-bezier(.32,.72,0,1), box-shadow .25s;
}
.btn-fill:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(45,58,82,.22); }
.btn-fill:active { transform: translateY(-1px); }
.btn-fill-arrow {
  width: 26px; height: 26px; border-radius: 50%;
  background: rgba(255,255,255,.15);
  display: flex; align-items: center; justify-content: center; font-size: 14px;
  transition: transform .25s cubic-bezier(.32,.72,0,1);
}
.btn-fill:hover .btn-fill-arrow { transform: translate(2px,-2px) scale(1.1); }
.btn-line {
  display: inline-flex; align-items: center; gap: 8px;
  background: transparent; color: rgba(45,58,82,.7);
  font-size: 15px; font-weight: 400; padding: 14px 28px;
  border-radius: 99px; text-decoration: none;
  border: 1px solid #E2E8F4;
  transition: border-color .2s, color .2s, transform .2s cubic-bezier(.32,.72,0,1);
}
.btn-line:hover { border-color: #7B9ED9; color: #2D3A52; transform: translateY(-2px); }
.scroll-hint {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  font-family: var(--font-mono); font-size: 10px; letter-spacing: .1em; text-transform: uppercase;
  color: rgba(45,58,82,.35);
  opacity: 0; animation: fadeUp .8s cubic-bezier(.16,1,.3,1) 1.2s forwards;
}
.scroll-line {
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, rgba(45,58,82,.3), transparent);
  animation: scrollDrop 1.5s ease-in-out infinite;
}
@keyframes scrollDrop {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  51%  { transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
@keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
@media (prefers-reduced-motion: reduce) {
  .hero-badge, .hero-h1, .hero-sub, .hero-btns, .scroll-hint { opacity: 1; transform: none; animation: none; }
  .orb, .scroll-line, .badge-dot { animation: none; }
}
</style>
