---
---

<dialog
  id="service-modal"
  class="fixed inset-0 z-[100] bg-transparent p-0 m-0 w-full h-full max-w-none max-h-none backdrop:bg-navy/40 backdrop:backdrop-blur-sm"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <div class="flex items-center justify-center w-full h-full px-4 py-8">
    <div class="bg-white rounded-[16px] w-full max-w-[520px] shadow-[0_24px_64px_rgba(45,58,82,0.18)] flex flex-col">

      <!-- Header -->
      <div class="flex items-start justify-between gap-4 p-7 pb-5">
        <div class="flex items-center gap-3">
          <div id="modal-icon" class="w-10 h-10 rounded-[10px] bg-card-bg flex items-center justify-center text-blue shrink-0"></div>
          <h2 id="modal-title" class="font-serif text-[22px] font-normal text-navy leading-tight"></h2>
        </div>
        <button
          id="modal-close"
          aria-label="Close"
          class="shrink-0 w-8 h-8 flex items-center justify-center rounded-lg text-navy opacity-40 hover:opacity-80 hover:bg-card-bg transition-all duration-150 mt-0.5"
        >
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
            <line x1="2" y1="2" x2="14" y2="14"/>
            <line x1="14" y1="2" x2="2" y2="14"/>
          </svg>
        </button>
      </div>

      <!-- Divider -->
      <div class="mx-7 h-px bg-border"></div>

      <!-- Body -->
      <div class="p-7 flex flex-col gap-5">
        <p id="modal-description" class="text-[14px] font-light text-navy opacity-70 leading-[1.75]"></p>

        <div>
          <p class="text-[11px] uppercase tracking-[0.08em] text-blue font-medium mb-3">What's included</p>
          <ul id="modal-includes" class="flex flex-col gap-2 list-none m-0 p-0"></ul>
        </div>
      </div>

      <!-- Footer -->
      <div class="px-7 pb-7 flex items-center justify-end gap-3">
        <button
          id="modal-cancel"
          class="px-5 py-2.5 rounded-[10px] text-[13px] font-normal text-navy border border-border hover:-translate-y-0.5 hover:shadow-[0_4px_10px_rgba(45,58,82,0.08)] transition-all duration-150 active:translate-y-0"
          style="border-width: 0.5px;"
        >
          Cancel
        </button>
        <a
          id="modal-cta"
          href="#"
          class="px-5 py-2.5 rounded-[10px] text-[13px] font-medium text-white bg-navy hover:-translate-y-0.5 hover:shadow-[0_4px_14px_rgba(45,58,82,0.22)] transition-all duration-150 active:translate-y-0"
        >
          Request this service
        </a>
      </div>

    </div>
  </div>
</dialog>

<script>
  const modal    = document.getElementById('service-modal') as HTMLDialogElement;
  const title    = document.getElementById('modal-title')!;
  const iconWrap = document.getElementById('modal-icon')!;
  const desc     = document.getElementById('modal-description')!;
  const list     = document.getElementById('modal-includes')!;
  const cta      = document.getElementById('modal-cta') as HTMLAnchorElement;
  const closeBtn = document.getElementById('modal-close')!;
  const cancelBtn = document.getElementById('modal-cancel')!;

  function openModal(card: HTMLElement) {
    title.textContent    = card.dataset.title ?? '';
    desc.textContent     = card.dataset.description ?? '';
    cta.href             = card.dataset.href ?? '#';
    iconWrap.innerHTML   = card.dataset.icon ?? '';

    const includes: string[] = JSON.parse(card.dataset.includes ?? '[]');
    list.innerHTML = includes
      .map(
        (item) => `
        <li class="flex items-start gap-2.5 text-[13px] font-light text-navy opacity-65 leading-[1.6]">
          <span class="mt-[5px] w-[5px] h-[5px] rounded-full bg-blue shrink-0"></span>
          ${item}
        </li>`
      )
      .join('');

    modal.showModal();
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.close();
    document.body.style.overflow = '';
  }

  // Close buttons
  closeBtn.addEventListener('click', closeModal);
  cancelBtn.addEventListener('click', closeModal);

  // Click outside (on the backdrop)
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // ESC is handled natively by <dialog>
  modal.addEventListener('close', () => {
    document.body.style.overflow = '';
  });

  // Listen for open events dispatched by the cards
  document.addEventListener('open-service-modal', (e) => {
    openModal((e as CustomEvent).detail);
  });
</script>
