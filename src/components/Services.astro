---
import Icon from './Icon.astro';
import { services } from '../data/services';

// Pre-render each icon to a string so we can pass it via data attribute
const iconMap: Record<string, string> = {
  grid:   `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  flask:  `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M9 3v7l-4 7a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 17l-4-7V3"/><line x1="6.5" y1="14" x2="17.5" y2="14"/></svg>`,
  robot:  `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><line x1="12" y1="7" x2="12" y2="11"/><circle cx="8" cy="15" r="1" fill="currentColor" stroke="none"/><circle cx="16" cy="15" r="1" fill="currentColor" stroke="none"/></svg>`,
  users:  `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M21 21v-2a4 4 0 0 0-3-3.85"/></svg>`,
  chart:  `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="18" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="18" cy="6" r="2"/><line x1="7.4" y1="16.7" x2="10.6" y2="13.3"/><line x1="13.4" y1="10.7" x2="16.6" y2="7.3"/></svg>`,
  school: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M2 8v6"/><path d="M6 10.5v5.5a6 6 0 0 0 12 0v-5.5"/></svg>`,
};
---

<section
  id="services"
  class="bg-white border-y border-border py-16 px-8"
  style="border-top-width: 0.5px; border-bottom-width: 0.5px;"
>
  <div class="max-w-[900px] mx-auto">
    <p class="text-[11px] uppercase tracking-[0.1em] text-blue mb-3">What we do</p>
    <h2 class="font-serif text-[36px] font-normal text-navy leading-[1.2] mb-2.5">
      Everything quality.<br />Nothing generic.
    </h2>
    <p class="text-[15px] font-light text-navy opacity-60 max-w-[480px] leading-[1.7] mb-11">
      We don't believe in copy-paste solutions. Every engagement is tailored to your product,
      your team, and where you want to go.
    </p>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 list-none m-0 p-0" role="list">
      {services.map((service) => (
        <li
          role="button"
          tabindex="0"
          class="rounded-[14px] p-6 border bg-white border-border cursor-pointer transition-all duration-200 ease-out hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(45,58,82,0.1)] hover:border-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue"
          style="border-width: 0.5px;"
          data-title={service.title}
          data-description={service.longDescription}
          data-includes={JSON.stringify(service.includes)}
          data-icon={iconMap[service.icon]}
          data-href={`/services/${service.slug}`}
        >
          <div class="w-[38px] h-[38px] rounded-[10px] bg-card-bg flex items-center justify-center mb-4">
            <Icon name={service.icon as any} class="w-[18px] h-[18px] text-blue" />
          </div>
          <h3 class="text-[15px] font-medium text-navy mb-2">{service.title}</h3>
          <p class="text-[13px] font-light text-navy opacity-65 leading-[1.65]">
            {service.description}
          </p>
          <p class="text-[11px] text-blue font-medium tracking-[0.04em] mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
            Learn more →
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-title][role="button"]').forEach((card) => {
    const trigger = () => {
      document.dispatchEvent(new CustomEvent('open-service-modal', { detail: card }));
    };
    card.addEventListener('click', trigger);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); trigger(); }
    });
  });
</script>
