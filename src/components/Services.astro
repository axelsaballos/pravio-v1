---
import { services } from '../data/services';

const icons: Record<string, string> = {
  grid:   `<svg viewBox="0 0 24 24" fill="none" stroke="#7B9ED9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  flask:  `<svg viewBox="0 0 24 24" fill="none" stroke="#7B9ED9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6M9 3v7l-4 7a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 17l-4-7V3"/><line x1="6.5" y1="14" x2="17.5" y2="14"/></svg>`,
  robot:  `<svg viewBox="0 0 24 24" fill="none" stroke="#7B9ED9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><line x1="12" y1="7" x2="12" y2="11"/><circle cx="8" cy="15" r="1" fill="#7B9ED9" stroke="none"/><circle cx="16" cy="15" r="1" fill="#7B9ED9" stroke="none"/></svg>`,
  users:  `<svg viewBox="0 0 24 24" fill="none" stroke="#7B9ED9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><path d="M16 3.13a4 4 0 0 1 0 7.75M21 21v-2a4 4 0 0 0-3-3.85"/></svg>`,
  chart:  `<svg viewBox="0 0 24 24" fill="none" stroke="#7B9ED9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="18" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="18" cy="6" r="2"/><line x1="7.4" y1="16.7" x2="10.6" y2="13.3"/><line x1="13.4" y1="10.7" x2="16.6" y2="7.3"/></svg>`,
  school: `<svg viewBox="0 0 24 24" fill="none" stroke="#7B9ED9" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M2 8v6M6 10.5v5.5a6 6 0 0 0 12 0v-5.5"/></svg>`,
};
---

<section id="services" class="services-section">
  <div class="reveal">
    <p class="s-label">What we do</p>
    <h2 class="s-h2">Everything quality.<br><em>Nothing generic.</em></h2>
    <p class="s-sub">Every engagement is tailored to your product, your team, and where you want to go.</p>
  </div>
  <div class="svc-grid reveal rd1">
    {services.map((service) => (
      <a href={`/services/${service.slug}`} class="svc-card">
        <div class="svc-icon-wrap" set:html={icons[service.icon]}></div>
        <div class="svc-title">{service.title}</div>
        <p class="svc-desc">{service.description}</p>
        <span class="svc-more">Learn more &#8599;</span>
      </a>
    ))}
  </div>
</section>

<style>
.services-section { padding: 120px 3rem; max-width: 1200px; margin: 0 auto; }
.s-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: #7B9ED9; margin-bottom: 16px; }
.s-h2 { font-size: clamp(34px, 4vw, 54px); font-weight: 200; letter-spacing: -.03em; line-height: 1.1; color: #2D3A52; margin-bottom: 16px; }
.s-h2 em { font-style: normal; font-weight: 400; }
.s-sub { font-size: 15px; font-weight: 300; color: rgba(45,58,82,.6); line-height: 1.75; max-width: 50ch; margin-bottom: 64px; }
.svc-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.svc-card {
  background: white; border: 1px solid #E2E8F4; border-radius: 16px; padding: 32px;
  position: relative; text-decoration: none; display: block;
  transition: border-color .2s cubic-bezier(.32,.72,0,1), transform .2s cubic-bezier(.32,.72,0,1), box-shadow .2s;
}
.svc-card:hover { border-color: #7B9ED9; transform: translateY(-3px); box-shadow: 0 12px 32px rgba(123,158,217,.12); }
.svc-icon-wrap {
  width: 38px; height: 38px; border-radius: 10px; background: #E8EDF5;
  display: flex; align-items: center; justify-content: center; margin-bottom: 18px;
}
.svc-title { font-size: 15px; font-weight: 500; color: #2D3A52; letter-spacing: -.015em; margin-bottom: 8px; line-height: 1.35; }
.svc-desc  { font-size: 13px; font-weight: 300; color: rgba(45,58,82,.6); line-height: 1.7; }
.svc-more  {
  display: inline-flex; align-items: center; gap: 5px;
  margin-top: 18px; font-size: 12px; color: #7B9ED9;
  opacity: 0; transform: translateX(-6px);
  transition: opacity .2s, transform .2s cubic-bezier(.32,.72,0,1);
}
.svc-card:hover .svc-more { opacity: 1; transform: translateX(0); }
@media (max-width: 960px) {
  .services-section { padding-left: 1.5rem; padding-right: 1.5rem; }
  .svc-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .services-section { padding-left: 1.25rem; padding-right: 1.25rem; }
  .svc-grid { grid-template-columns: 1fr; }
}
</style>
